@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section d-flex align-items-center justify-content-center text-center text-white">
    <div class="container">
        <i class="bg-info bi-play-circle-fill text-white opacity-75 mb-3" style="font-size:4rem;"></i>

        <h1 class="display-3 fw-bold mb-3"> Czas na kolejną przygodę</h1>
        <p class="lead mb-4 fw-light"> Szlaki turystyczne w Tatrach</p>

        <a href="#o-tatrach" class="btn btn-warning btn-lg fw-bold rounded-pill px-5 py-3 text-white">
            Rozpocznij przygodę
        </a>
    </div>
</section>

<section id="o-tatrach" class="about-tatry py-5 bg-light">
    <div class="container">

        <div class="d-flex flex-column flex-md-row gap-5 align-items-center">
            <div class="about-content flex-1 text-center text-md-start">
                <div class="mb-2">
                    <img src="~/images/logo_ikona.png" alt="Logo" style="height:40px; width: auto;">
                </div>

                <h2 class="display-5 fw-bold text-dark mb-3">O Tatrach</h2>
                <p class="text-muted mb-4">
                    Tatry to najwyższe pasmo górskie w łańcuchu Karpat, oferujące niezapomniane widoki,
                    wymagające szlaki oraz unikalną faunę i florę. Nasz blog powstał z pasji do gór,
                    aby pomóc Ci zaplanować bezpieczną i pełną przygód wędrówkę. Odkryj z nami najpiękniejsze zakątki!
                </p>

                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start">
                    <a href="#polecane" class="btn btn-warning fw-bold rounded-pill px-4 py-2 text-white shadow-sm">
                        Najlepsze szlaki
                    </a>
                    <a href="#lista" class="btn btn-outline-warning fw-bold rounded-pill px-4 py-2 shadow-sm">
                        Lista szlaków
                    </a>
                </div>
            </div>

            <div class="about-img-box flex-1 text-center">
                <img src="~/images/o-tatrach.jpg" alt="Przygoda w Tatrach" class="img-fluid rounded-3 shadow" style="max-height: 450px; object-fit:cover;">
            </div>
        </div>
    </div>
</section>

<section id="polecane-szlaki" class="recommended-trails py-5 text-white" style="background-color: #2c1d11;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-2">Polecane szlaki</h2>
            <p class="opacity-75">Wybierz swoją trasę i ruszaj w drogę</p>
        </div>

        <div class="row g-4">

            <div class="col-md-4">
                <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                    <img src="~/images/teryho.jpg" class="card-img-top rounded-top" alt="Szlak na chatę Teryho - Słowacja" style="height: 200px; object-fit:cover;">
                    <div class="card-body d-flex flex-column text-center justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Hrebieniok &rarr; Chata Teryho</h5>
                            <p class="card-text opacity-75 small mb-4">
                                Wspaniała wędrówka w Tatrach Wysokich na Słowacji. Szlak prowadzi przez Dolinę Małej Zimnej Wody aż do najwyżej położonego całorocznego schroniska.
                            </p>
                        </div>
                        <a href="szlaki/teryho" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                            Zobacz szczegóły
                        </a>
                    </div>
                </div>
            </div> <div class="col-md-4">
                <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                    <img src="~/images/czarny_staw.jpg" class="card-img-top rounded-top" alt="Szlak na Czarny Staw Gąsienicowy - Polska" style="height: 200px; object-fit:cover;">
                    <div class="card-body d-flex flex-column text-center justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Kuźnice &rarr; Czarny Staw Gąsienicowy</h5>
                            <p class="card-text opacity-75 small mb-4">
                                Niezwykle malownicza trasa prowadząca przez Halę Gąsienicową. Widok na surowe, skaliste szczyty otaczające czarny staw zapiera dech w piersiach.
                            </p>
                        </div>
                        <a href="szlaki/czarny-staw" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                            Zobacz szczegóły
                        </a>
                    </div>
                </div>
            </div> <div class="col-md-4">
                <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                    <img src="~/images/zawrat.jpg" class="card-img-top rounded-top" alt="Szlak na Zawrat z D5SP - Polska" style="height: 200px; object-fit:cover;">
                    <div class="card-body d-flex flex-column text-center justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">D5SP &rarr; Zawrat</h5>
                            <p class="card-text opacity-75 small mb-4">
                                Propozycja dla ambitniejszych turystów. Szlak pnie się w górę z urokliwej doliny na słynną przełęcz, oferując wymagające podejścia i niezapomniane panoramy.
                            </p>
                        </div>
                        <a href="szlaki/zawrat" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                            Zobacz szczegóły
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="lista_szlakow" class="hiking-trails py-5 bg-light ">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-2"> Lista szlaków</h2>
        </div>

        <div class="filter-panel p-4 rounded-3 shadow-sm mb-5" style="background-color: #f8f9fa; border: 1px solid #e8ecef;">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <label for="filter-difficulty" class="form-label fw-bold text-dark"> Trudność: </label>
                    <select id="filter-difficulty" class="form-select">
                        <option value="all"> Wszystkie </option>
                        <option value="easy"> Łatwy </option>
                        <option value="medium"> Średniozaawansowany </option>
                        <option value="hard"> Zaawansowany </option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="filter-length" class="form-label fw-bold text-dark"> Długość szlaku (max km): </label>
                    <input type="number" id="filter-length" class="form-control" placeholder="- km" />
                </div>
                <div class="col-md-4 d-flex align-bottom align-items-end">
                    <button id="btn-filter" class="btn btn-warning fw-bold text-white text-center w-100 rounded-pill"> Filtruj</button>
                </div>
            </div>
        </div>
        <div class="table-responsive rounded-3 shadow-sm">
            <div class="mb-4 d-flex gap-2">
                <button class="btn btn-secondary btn-sm filter-btn" data-target="all">Wszystkie</button>
                <button class="btn btn-success btn-sm filter-btn" data-target="easy">Łatwy</button>
                <button class="btn btn-primary btn-sm filter-btn" data-target="medium">Średniozaawansowany</button>
            </div>
            <table class="table table-hover table-striped align-middle mb-0" id="trails-table">
                <thead>
                    <tr>
                        <th scope="col"> Nazwa szlaku (skąd -> dokąd) </th>
                        <th scope="col"> Trudność</th>
                        <th scope="col"> Długość</th>
                        <th scope="col"> Kolor szlaków</th>
                        <th scope="col"> Czas przejścia</th>
                        <th scope="col" class="text-center"> Zobacz</th>
                    </tr>
                </thead>
                <tbody>
                    <tr data-difficulty="medium">
                        <td> class="fw-bold px-4"> Hrebieniok &rarr; Chata Teryho </td>
                        <td> Średniozaawanasowany</td>
                        <td> 6.6 km</td>
                        <td> Zielony </td>
                        <td> 3 h</td>
                        <td class="text-center">
                            <a href="szlaki/teryho" class="btn btn-outline-warning btn-sm fw-bold rounded-pill"> Zobacz opis</a>
                        </td>
                    </tr>
                    <tr data-difficulty="easy"> 
                        <td>class="fw-bold px-4"> Kuźnice &rarr; Czarny Staw Gąsienicowy </td>
                        <td> Łatwy </td>
                        <td> 6.3 km</td>
                        <td> Niebieski </td>
                        <td> 3 h</td>
                        <td class="text-center">
                            <a href="szlaki/czarny-staw" class="btn btn-outline-warning btn-sm fw-bold rounded-pill"> Zobacz opis</a>
                        </td>
                    </tr>
                </tbody>

            </table>
        </div>
    </div>

</section>

