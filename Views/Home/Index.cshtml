@{
    ViewData["Title"] = "Strona Główna - Tatry";
}

<section class="hero-section d-flex align-items-center justify-content-center text-center text-white">
    <div class="container">
        <i class="bg-info bi-play-circle-fill text-white opacity-75 mb-3" style="font-size:4rem;"></i>
        <h1 class="display-3 fw-bold mb-3">Czas na kolejną przygodę</h1>
        <p class="lead mb-4 fw-light">Szlaki turystyczne w Tatrach</p>
        <a href="#o-tatrach" class="btn btn-warning btn-lg fw-bold rounded-pill px-5 py-3 text-white">
            Rozpocznij przygodę
        </a>
    </div>
</section>

<section id="o-tatrach" class="about-tatry py-5 bg-light">
    <div class="container">
        <div class="d-flex flex-column flex-md-row gap-5 align-items-center">
            <div class="about-content flex-1 text-center text-md-start">
                <div class="mb-2">
                    <img src="~/images/logo_ikona.png" alt="Logo" style="height:40px; width: auto;">
                </div>
                <h2 class="display-5 fw-bold text-dark mb-3">O Tatrach</h2>
                <p class="text-muted mb-4">
                    Tatry to najwyższe pasmo górskie w łańcuchu Karpat, oferujące niezapomniane widoki,
                    wymagające szlaki oraz unikalną faunę i florę. Nasz blog powstał z pasji do gór,
                    bi pomagać Ci zaplanować bezpieczną i pełną przygód wędrówkę.
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start">
                    <a href="#polecane" class="btn btn-warning fw-bold rounded-pill px-4 py-2 text-white shadow-sm">
                        Najlepsze szlaki
                    </a>
                    <a href="#lista" class="btn btn-outline-warning fw-bold rounded-pill px-4 py-2 shadow-sm">
                        Lista szlaków
                    </a>
                </div>
            </div>
            <div class="about-img-box flex-1 text-center">
                <img src="~/images/o-tatrach.jpg" alt="Przygoda w Tatrach" class="img-fluid rounded-3 shadow" style="max-height: 450px; object-fit:cover;">
            </div>
        </div>
    </div>
</section>

<section id="polecane" class="recommended-trails py-5 text-white" style="background-color: #2c1d11;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-2">Polecane szlaki</h2>
            <p class="opacity-75">Wybierz swoją trasę i ruszaj w drogę</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                    <img src="~/images/teryho.jpg" class="card-img-top rounded-top" alt="Szlak na chatę Teryho" style="height: 200px; object-fit:cover;">
                    <div class="card-body d-flex flex-column text-center justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Hrebieniok &rarr; Chata Teryho</h5>
                            <p class="card-text opacity-75 small mb-4">
                                Wspaniała wędrówka w Tatrach Wysokich na Słowacji. Szlak prowadzi przez Dolinę Małej Zimnej Wody.
                            </p>
                        </div>
                        <a href="/Szlaki" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                            Zobacz wszystkie
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                    <img src="~/images/czarny_staw.jpg" class="card-img-top rounded-top" alt="Szlak na Czarny Staw" style="height: 200px; object-fit:cover;">
                    <div class="card-body d-flex flex-column text-center justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">Kuźnice &rarr; Czarny Staw Gąsienicowy</h5>
                            <p class="card-text opacity-75 small mb-4">
                                Niezwykle malownicza trasa prowadząca przez Halę Gąsienicową. Widok zapiera dech w piersiach.
                            </p>
                        </div>
                        <a href="/Szlaki" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                            Zobacz wszystkie
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                    <img src="~/images/zawrat.jpg" class="card-img-top rounded-top" alt="Szlak na Zawrat" style="height: 200px; object-fit:cover;">
                    <div class="card-body d-flex flex-column text-center justify-content-between">
                        <div>
                            <h5 class="card-title fw-bold mb-2">D5SP &rarr; Zawrat</h5>
                            <p class="card-text opacity-75 small mb-4">
                                Propozycja dla ambitniejszych turystów. Szlak pnie się w górę z urokliwej doliny na słynną przełęcz.
                            </p>
                        </div>
                        <a href="/Szlaki" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                            Zobacz wszystkie
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>