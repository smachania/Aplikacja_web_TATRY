@{
    ViewData["Title"] = "Szczegóły szlaku";
}

<section class="trail-hero text-center  text-white py-5" style="background-color: #3d2a1a;">
    <div class="container pt-5">
        <h1 class="display-3 fw-bold mb-3"> Kuźnice &rarr; Czarny Staw Gąsienicowy </h1>

        <p class="lead opacity-75 mb-0"> Niezwykle malownicza trasa prowadząca przez Halę Gąsienicową</p>

    </div>
</section>

<section class="trail-stats py-4 bg-light border-bottom">
    <div class="container">
        <div class="row text-center">

            <div class="col-md-3 col-6 mb-3">
                <div class="p-3 border rounded-3 bg-white shadow-sm">
                    <h6 class="text-muted mb-1"> Trudność </h6>
                    <p class="fw-bold mb-0 text-succes"> Łatwy </p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-3">
                <div class="p-3 border rounded-3 bg-white shadow-sm">
                    <h6 class="text-muted mb-1"> Długość </h6>
                    <p class="fw-bold mb-0 text-dark"> 6.3 km </p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-3">
                <div class="p-3 border rounded-3 bg-white shadow-sm">
                    <h6 class="text-muted mb-1"> Kolor szlaku </h6>
                    <p class="fw-bold mb-0 text-dark"> Niebieski </p>
                </div>
            </div>
            <div class="col-md-3 col-6 mb-3">
                <div class="p-3 border rounded-3 bg-white shadow-sm">
                    <h6 class="text-muted mb-1"> Czas przejścia </h6>
                    <p class="fw-bold mb-0 text-dark"> 3h </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="trail-description py-5">
    <div class="container">
        <div class="row align-items-center">

            <div class="col-md-6 mb-4 mb-md-0">
                <h3 class="fw-bold mb-3"> Przebieg trasy</h3>
                <p class="text-muted">
                    Wędrówka rozpoczyna się w Kuźnicach, skąd ruszamy niebieskim szlakiem przez Boczań lub Dolinę Jaworzynki.
                    Obie ścieżki łączą się na Przełęczy między Kopami, skąd otwiera się już piękny widok na Tatry Wysokie.
                    Stamtąd łagodnym podejściem docieramy do Hali Gąsienicowej, a stamtąd już tylko krótki spacer dzieli nas od brzegów Czarnego Stawu.
                </p>
                <p class="text-muted">
                    To świetna trasa na rozgrzewkę przed trudniejszymi wyprawami, oferująca jedne z najpiękniejszych panoram w Tatrach Zachodnich i Wysokich.
                </p>
            </div>

            <div class="col-md-6 text-center">
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded-3 shadow" style="height:300px;">

                </div>
            </div>
        </div>
    </div>
</section>

<div class="container pb-5 text-center">
    <a href="/" class="btn btn-outline-secondary fw-bold rounded-pill px-4">
        &larr; Powrót do listy szlaków
        </a>
</div>