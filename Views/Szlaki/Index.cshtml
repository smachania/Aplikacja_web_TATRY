@model IEnumerable<App_web_Tatry.Entities.Szlak>

@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section d-flex align-items-center justify-content-center text-center text-white">
    <div class="container">
        <i class="bg-info bi-play-circle-fill text-white opacity-75 mb-3" style="font-size:4rem;"></i>
        <h1 class="display-3 fw-bold mb-3">Czas na kolejną przygodę</h1>
        <p class="lead mb-4 fw-light">Szlaki turystyczne w Tatrach</p>
        <a href="#o-tatrach" class="btn btn-warning btn-lg fw-bold rounded-pill px-5 py-3 text-white">
            Rozpocznij przygodę
        </a>
    </div>
</section>

<section id="o-tatrach" class="about-tatry py-5 bg-light">
    <div class="container">
        <div class="d-flex flex-column flex-md-row gap-5 align-items-center">
            <div class="about-content flex-1 text-center text-md-start">
                <div class="mb-2">
                    <img src="~/images/logo_ikona.png" alt="Logo" style="height:40px; width: auto;">
                </div>
                <h2 class="display-5 fw-bold text-dark mb-3">O Tatrach</h2>
                <p class="text-muted mb-4">
                    Tatry to najwyższe pasmo górskie w łańcuchu Karpat, oferujące niezapomniane widoki,
                    wymagające szlaki oraz unikalną faunę i florę. Nasz blog powstał z pasji do gór,
                    aby pomóc Ci zaplanować bezpieczną i pełną przygód wędrówkę. Odkryj z nami najpiękniejsze zakątki!
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-start">
                    <a href="#polecane" class="btn btn-warning fw-bold rounded-pill px-4 py-2 text-white shadow-sm">
                        Najlepsze szlaki
                    </a>
                    <a href="#lista" class="btn btn-outline-warning fw-bold rounded-pill px-4 py-2 shadow-sm">
                        Lista szlaków
                    </a>
                </div>
            </div>
            <div class="about-img-box flex-1 text-center">
                <img src="~/images/o-tatrach.jpg" alt="Przygoda w Tatrach" class="img-fluid rounded-3 shadow" style="max-height: 450px; object-fit:cover;">
            </div>
        </div>
    </div>
</section>

<section id="polecane" class="recommended-trails py-5 text-white" style="background-color: #2c1d11;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-2">Polecane szlaki</h2>
            <p class="opacity-75">Wybierz swoją trasę i ruszaj w drogę</p>
        </div>

        <div class="row g-4">
            @foreach (var item in Model.Take(3))
            {
                // Sprawdzamy, czy szlak ma zdjęcia, jeśli nie - dajemy placeholder
                var glowneZdjecie = item.Zdjecia.FirstOrDefault()?.SciezkaPliku ?? "/images/o-tatrach.jpg";

                <div class="col-md-4">
                    <div class="card h-100 border-0 text-white" style="background-color: #3d2a1a;">
                        <img src="@glowneZdjecie" class="card-img-top rounded-top" alt="@item.Nazwa" style="height: 200px; object-fit:cover;">
                        <div class="card-body d-flex flex-column text-center justify-content-between">
                            <div>
                                <h5 class="card-title fw-bold mb-2">@item.Nazwa</h5>
                                <p class="card-text opacity-75 small mb-4">
                                    @(item.Opis.Length > 150 ? item.Opis.Substring(0, 147) + "..." : item.Opis)
                                </p>
                            </div>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning btn-sm fw-bold rounded-pill text-white align-self-center px-3">
                                Zobacz szczegóły
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="lista" class="hiking-trails py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-2">Lista szlaków</h2>
        </div>

        <div class="filter-panel p-4 rounded-3 shadow-sm mb-5" style="background-color: #f8f9fa; border: 1px solid #e8ecef;">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <label for="filter-length" class="form-label fw-bold text-dark">Długość szlaku (max km):</label>
                    <input type="number" id="filter-length" class="form-control" placeholder="- km" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button id="btn-filter" class="btn btn-warning fw-bold text-white text-center w-100 rounded-pill">Filtruj</button>
                </div>
            </div>
        </div>

        <div class="table-responsive rounded-3 shadow-sm">
            <div class="mb-4 d-flex gap-2">
                <button class="btn btn-secondary btn-sm filter-btn" data-target="all">Wszystkie</button>
                <button class="btn btn-success btn-sm filter-btn" data-target="Łatwy">Łatwy</button>
                <button class="btn btn-primary btn-sm filter-btn" data-target="Średniozaawansowany">Średniozaawansowany</button>
                <button class="btn btn-danger btn-sm filter-btn" data-target="Zaawansowany">Zaawansowany</button>
            </div>

            <table class="table table-hover table-striped align-middle mb-0" id="trails-table">
                <thead>
                    <tr>
                        <th scope="col">Nazwa szlaku (skąd -> dokąd)</th>
                        <th scope="col">Trudność</th>
                        <th scope="col">Długość</th>
                        <th scope="col">Kolor szlaków</th>
                        <th scope="col">Czas przejścia</th>
                        <th scope="col" class="text-center">Zobacz</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // Przygotowanie wartości data-difficulty zgodnej z przyciskami
                        <tr data-difficulty="@item.PoziomTrudnosci" data-length="@item.Dlugosc.ToString("G", System.Globalization.CultureInfo.InvariantCulture)">
                            <td class="fw-bold px-4">@item.Nazwa</td>
                            <td>@item.PoziomTrudnosci</td>
                            <td>@item.Dlugosc km</td>
                            <td>@item.KolorSzlakow</td>
                            <td>@item.CzasPrzejscia h</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm fw-bold rounded-pill">Zobacz opis</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        const przyciskiTrudnosci = document.querySelectorAll('.filter-btn');
        const wiersze = document.querySelectorAll('table tbody tr');
        const poleDlugosci = document.querySelector('#filter-length');
        const przyciskFiltruj = document.querySelector('#btn-filter');
        let aktualnyPoziom = 'all';

        function filtrujSzlaki() {
            const wpisanaDlugosc = parseFloat(poleDlugosci.value.replace(',', '.'));

            wiersze.forEach(function(wiersz) {
                const trudnoscWiersza = wiersz.getAttribute('data-difficulty');
                const dlugoscWiersza = parseFloat(wiersz.getAttribute('data-length'));

                const pasujeTrudnosc = (aktualnyPoziom === 'all' || trudnoscWiersza === aktualnyPoziom);
                const pasujeDlugosc = (isNaN(wpisanaDlugosc) || dlugoscWiersza <= wpisanaDlugosc);

                if (pasujeDlugosc && pasujeTrudnosc) {
                    wiersz.style.display = '';
                } else {
                    wiersz.style.display = 'none';
                }
            });
        }

        przyciskiTrudnosci.forEach(function(przycisk) {
            przycisk.addEventListener('click', function() {
                aktualnyPoziom = przycisk.getAttribute('data-target');
                filtrujSzlaki();
            });
        });

        przyciskFiltruj.addEventListener('click', function() {
            filtrujSzlaki();
        });
    </script>
}
