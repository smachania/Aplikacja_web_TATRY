@model App_web_Tatry.Entities.Szlak

@{
    ViewData["Title"] = "Delete";
}

<div class="container pt-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 card p-4 shadow-sm bg-white text-dark rounded-3">

            <h1 class="text-center fw-bold text-danger mb-1">Delete</h1>
            <h3 class="text-center text-muted fs-6 mb-3">Are you sure you want to delete this?</h3>
            <hr />

            <div class="bg-light p-3 rounded-3 mb-4 border">
                <h4 class="small text-muted mb-3">App_web_Tatry.Entities.Szlak</h4>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-secondary small">@Html.DisplayNameFor(model => model.Nazwa)</dt>
                    <dd class="col-sm-8 fw-bold">@Html.DisplayFor(model => model.Nazwa)</dd>

                    <dt class="col-sm-4 text-secondary small">@Html.DisplayNameFor(model => model.Opis)</dt>
                    <dd class="col-sm-8 text-muted small">@Html.DisplayFor(model => model.Opis)</dd>

                    <dt class="col-sm-4 text-secondary small">@Html.DisplayNameFor(model => model.Dlugosc)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Dlugosc) km</dd>

                    <dt class="col-sm-4 text-secondary small">@Html.DisplayNameFor(model => model.CzasPrzejscia)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.CzasPrzejscia) h</dd>

                    <dt class="col-sm-4 text-secondary small">@Html.DisplayNameFor(model => model.PoziomTrudnosci)</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Html.DisplayFor(model => model.PoziomTrudnosci)</span></dd>

                    <dt class="col-sm-4 text-secondary small">@Html.DisplayNameFor(model => model.KolorSzlakow)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.KolorSzlakow)</dd>
                </dl>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-grid gap-2">
                    <input type="submit" value="Delete" class="btn btn-danger fw-bold rounded-pill" />
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill mt-1">Back to List</a>
                </div>
            </form>

        </div>
    </div>
</div>